# Pandion provider credentials — template.
#
# Copy to `.env` (gitignored) and fill in the keys for whichever providers you
# want to use / e2e-test. Pandion reads the environment first, then the OS
# keychain (`pandion login`), so exporting these is enough:
#
#   cp .env.example .env
#   # edit .env, then:
#   set -a; source .env; set +a
#   ./scripts/e2e_<provider>.sh

# Hetzner
HCLOUD_TOKEN=

# DigitalOcean
DIGITALOCEAN_TOKEN=

# Vultr (single API key)
VULTR_API_KEY=

# Linode / Akamai (single personal access token)
LINODE_TOKEN=

# Scaleway (a triple — only SCW_SECRET_KEY is sensitive; the other two are
# non-secret identifiers). Create an API key in the Scaleway console.
SCW_SECRET_KEY=
SCW_ACCESS_KEY=
SCW_DEFAULT_PROJECT_ID=
